{
    "geode": "5.5.3",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081",
        "ios": "2.2081"
    },
    "version": "v1.0.0",
    "id": "malikhw47.orbit-screensaver",
    "name": "Orbit Ballpit Screensaver",
    "developer": "MalikHw47",
    "description": "A physics ballpit screensaver that runs on top of GD after idle time.",
    "tags": ["gameplay", "enhancement", "utility"],
    "links": {
        "homepage": "https://malikhw.github.io",
        "source": "https://github.com/MalikHw/orbit-screensaver-gd",
        "community": "https://discord.gg/G9bZ92eg2n"
    },
    "settings": {
        "physics-title": {
            "type": "title",
            "name": "Physics & Simulation"
        },
        "idle-timeout": {
            "name": "Idle Timeout (seconds)",
            "description": "How many seconds of no input before the screensaver appears.",
            "type": "int",
            "default": 30,
            "min": 5,
            "max": 300,
            "control": {
                "slider": true,
                "arrows": true,
                "arrow-step": 5
            }
        },
        "orb-speed": {
            "name": "Speed",
            "description": "Gravity speed multiplier.",
            "type": "int",
            "default": 10,
            "min": 1,
            "max": 20,
            "control": {
                "slider": true,
                "arrows": true
            }
        },
        "orbs-title": {
            "type": "title",
            "name": "Orbs"
        },
        "orb-count": {
            "name": "Orb Count",
            "description": "Total number of orbs/objects to spawn each cycle.",
            "type": "int",
            "default": 120,
            "min": 1,
            "max": 300,
            "control": {
                "slider": true,
                "arrows": true,
                "arrow-step": 10
            }
        },
        "orb-scale": {
            "name": "Orb Size",
            "description": "Scale multiplier for all spawned orbs.",
            "type": "float",
            "default": 1.0,
            "min": 0.3,
            "max": 3.0,
            "control": {
                "slider": true,
                "arrows": false
            }
        },
        "cube-title": {
            "type": "title",
            "name": "Player Cube"
        },
        "cube-chance": {
            "name": "Cube Spawn Chance (%)",
            "description": "Probability (0-100) that your equipped cube will also appear in the ballpit.",
            "type": "int",
            "default": 50,
            "min": 0,
            "max": 100,
            "control": {
                "slider": true,
                "arrows": true
            }
        },
        "misc-title": {
            "type": "title",
            "name": "Misc"
        },
        "no-ground": {
            "name": "No Ground (Infinite Fall)",
            "description": "Orbs fall off the bottom of the screen instead of piling up.",
            "type": "bool",
            "default": false
        }
    }
}
