{
    "geode": "5.5.3",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081",
        "ios": "2.2081"
    },
    "version": "v1.0.0",
    "id": "malikhw47.orbit-screensaver",
    "name": "Orbit Ballpit Screensaver",
    "developer": "MalikHw47",
    "description": "Orbit Ballpit screensaver that activates when you're idle anywhere in GD.",
    "repository": "https://github.com/MalikHw/orbit-screensaver-gd",
    "tags": ["customization", "interface", "offline", "universal"],
    "settings": {
        "general-title": {
            "type": "title",
            "name": "General"
        },
        "enabled": {
            "name": "Toggle",
            "description": "toggle the screensaver on or off",
            "type": "bool",
            "default": true
        },
        "idle-time": {
            "name": "Idle Time (secs)",
            "description": "how many seconds of no input before the screensaver activates?",
            "type": "int",
            "default": 30,
            "min": 5,
            "max": 300,
            "control": {
                "arrows": true,
                "arrow-step": 5,
                "big-arrows": true,
                "big-arrow-step": 30,
                "slider": true,
                "slider-step": 5,
                "input": true
            }
        },
        "physics-title": {
            "type": "title",
            "name": "physics"
        },
        "orb-count": {
            "name": "Orb count",
            "description": "how many orbs to spawn in the ballpit?",
            "type": "int",
            "default": 40,
            "min": 1,
            "max": 200,
            "control": {
                "arrows": true,
                "arrow-step": 5,
                "big-arrows": true,
                "big-arrow-step": 20,
                "slider": true,
                "input": true
            }
        },
        "orb-scale": {
            "name": "orb size",
            "description": "scale multiplier for all orbs",
            "type": "float",
            "default": 1.0,
            "min": 0.3,
            "max": 3.0,
            "control": {
                "arrows": true,
                "arrow-step": 0.1,
                "slider": true,
                "slider-step": 0.1
            }
        },
        "speed": {
            "name": "gravity speed",
            "description": "how fast gravity pulls the orbs down?",
            "type": "float",
            "default": 1.0,
            "min": 0.1,
            "max": 3.0,
            "control": {
                "arrows": true,
                "arrow-step": 0.1,
                "slider": true,
                "slider-step": 0.1
            }
        },
        "no-ground": {
            "name": "no ground (Infinite Fall)",
            "description": "When enabled, orbs fall through the bottom and reset, basically drain mode",
            "type": "bool",
            "default": false
        },
        "cube-chance": {
            "name": "Cube Spawn Chance (%)",
            "description": "chance (0-100) that your player cube icon also spawns in the ballpit?",
            "type": "int",
            "default": 50,
            "min": 0,
            "max": 100,
            "control": {
                "slider": true,
                "slider-step": 5,
                "arrows": true,
                "arrow-step": 5,
                "input": true
            }
        },
        "visual-title": {
            "type": "title",
            "name": "visuals"
        },
        "bg-color": {
            "name": "background color",
            "description": "background color of the screensaver overlay",
            "type": "rgba",
            "default": [0, 0, 0, 230]
        },
        "dismiss-on-click": {
            "name": "Dismiss on Any Input",
            "description": "Dismiss the screensaver when the player clicks, taps, or presses a key.",
            "type": "bool",
            "default": true
        }
    }
}
