{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081",
        "ios": "2.2081"
    },
    "version": "v1.1.2",
    "id": "malikhw47.orbit-screensaver",
    "name": "ORBIT Screensaver",
    "developer": "MalikHw47",
    "description": "A orbs ballpit screensaver for GD.",
    "tags": [ "offline", "customization", "interface", "universal"],
    "repository": "https://github.com/MalikHw/orbit-screensaver-gd",
    "links": {
        "homepage": "https://malikhw.github.io/orbit-screensaver",
        "community": "https://discord.gg/G9bZ92eg2n"
    },
    "issues": {
        "url": "https://github.com/MalikHw/orbit-screensaver-gd/issues",
        "info": "just say in <cl>the github issues</c>, feature requests allowed</c>"
    },
    "settings": {
        "physics-title": {
            "type": "title",
            "name": "Physics"
        },
        "idle-timeout": {
            "name": "Idle Timeout (seconds)",
            "description": "delay in seconds of no input before the screen saver appears",
            "type": "int",
            "default": 30,
            "min": 5,
            "max": 300,
            "control": {
                "slider": true,
                "arrows": true,
                "arrow-step": 5
            }
        },
        "orb-speed": {
            "name": "Speed",
            "description": "Gravity speed multiplier",
            "type": "int",
            "default": 10,
            "min": 1,
            "max": 20,
            "control": {
                "slider": true,
                "arrows": true
            }
        },
        "orbs-title": {
            "type": "title",
            "name": "orbs"
        },
        "orb-count": {
            "name": "Orb Count",
            "description": "Total number of orbs to show each cycle.",
            "type": "int",
            "default": 120,
            "min": 1,
            "max": 300,
            "control": {
                "slider": true,
                "arrows": true,
                "arrow-step": 10
            }
        },
        "cube-title": {
            "type": "title",
            "name": "Player Cube"
        },
        "cube-chance": {
            "name": "Cube Spawn Chance (%)",
            "description": "Probability (0-100) that your cube will also appear in the ball pit",
            "type": "int",
            "default": 50,
            "min": 0,
            "max": 100,
            "control": {
                "slider": true,
                "arrows": true
            }
        },
        "bg-title": {
            "type": "title",
            "name": "Background"
        },
        "bg-type": {
            "name": "Background Type",
            "description": "background type (blur requires BlurAPI)",
            "type": "string",
            "default": "color",
            "one-of": ["color", "image", "blur"]
        },
        "bg-color": {
            "name": "Background Color",
            "description": "Color used for the background overlay (RGB, no alpha here)",
            "type": "rgb",
            "default": [0, 0, 0]
        },
        "bg-opacity": {
            "name": "Background Opacity",
            "description": "Opacity of the background (0 = fully transparent, 255 = fully opaque)",
            "type": "int",
            "default": 200,
            "min": 0,
            "max": 255
        },
        "bg-image": {
            "name": "Background Image",
            "description": "path to an image file. Only used when Background Type is set to image",
            "type": "file",
            "default": ""
        },
        "bg-fit": {
            "name": "Image Fit",
            "description": "How the image fills the screen. stretch = fills. zoom = maintains aspect ratio, crops edges",
            "type": "string",
            "default": "stretch",
            "one-of": ["stretch", "zoom"]
        },
        "misc-title": {
            "type": "title",
            "name": "Misc"
        },
        "no-ground": {
            "name": "No Ground (Infinite Fall)",
            "description": "Orbs fall off the bottom of the screen instead of filling up (rip Hdanke)",
            "type": "bool",
            "default": false
        }
    },
    "dependencies": {
        "thesillydoggo.blur-api": {
            "version": ">=v1.0.0",
            "required": false
        }
    }
}
