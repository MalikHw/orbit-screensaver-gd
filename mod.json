{
    "geode": "5.5.3",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081"
    },
    "version": "v1.0.0-beta",
    "id": "malikhw47.orbit-screensaver",
    "name": "ORBIT Screensaver",
    "developer": "MalikHw47",
    "description": "A screensaver for GD.",
    "tags": [ "offline", "customization", "interface", "universal"],
    "links": {
        "source": "https://github.com/MalikHw/orbit-screensaver-gd",
        "community": "https://discord.gg/G9bZ92eg2n"
    },
    "settings": {
        "physics-title": {
            "type": "title",
            "name": "Physics"
        },
        "idle-timeout": {
            "name": "Idle Timeout (seconds)",
            "description": "delay in seconds of no input before the screen saver appears",
            "type": "int",
            "default": 30,
            "min": 5,
            "max": 300,
            "control": {
                "slider": true,
                "arrows": true,
                "arrow-step": 5
            }
        },
        "orb-speed": {
            "name": "Speed",
            "description": "Gravity speed multiplier",
            "type": "int",
            "default": 10,
            "min": 1,
            "max": 20,
            "control": {
                "slider": true,
                "arrows": true
            }
        },
        "orbs-title": {
            "type": "title",
            "name": "Orbs"
        },
        "orb-count": {
            "name": "Orb Count",
            "description": "Total number of orbs to show each cycle.",
            "type": "int",
            "default": 120,
            "min": 1,
            "max": 300,
            "control": {
                "slider": true,
                "arrows": true,
                "arrow-step": 10
            }
        },
        "cube-title": {
            "type": "title",
            "name": "Player Cube"
        },
        "cube-chance": {
            "name": "Cube Spawn Chance (%)",
            "description": "Probability (0-100) that your cube will also appear in the ball pit",
            "type": "int",
            "default": 50,
            "min": 0,
            "max": 100,
            "control": {
                "slider": true,
                "arrows": true
            }
        },
        "bg-title": {
            "type": "title",
            "name": "Background"
        },
        "bg-color": {
            "name": "Background Color & Opacity",
            "description": "Color and opacity of the screensaver overlay.(transparent possibwe uwu)",
            "type": "rgba",
            "default": "#000000ff"
        },
        "bg-blur": {
            "name": "Blur Background",
            "description": "Blur the scene behind the screensaver (requires Blur API to be installed and enabled).",
            "type": "bool",
            "default": false
        },
        "misc-title": {
            "type": "title",
            "name": "Misc"
        },
        "no-ground": {
            "name": "No Ground (Infinite Fall)",
            "description": "Orbs fall off the bottom of the screen instead of filling up (rip Hdanke)",
            "type": "bool",
            "default": false
        }
    },
    "suggested": [
        {
            "id": "thesillydoggo.blur-api",
            "importance": "recommended",
            "reason": "Enables blur background option"
        }
    ]
}
